{
  "buildCommand": null,
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/b/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow, noarchive" },
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
